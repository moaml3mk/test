    border-radius: 14px 4px 14px 14px;
  }

  .chat-sender {
    font-size: 11px;
    color: var(--neon-blue);
    font-weight: 600;
    margin-bottom: 3px;
  }

  .chat-msg.own .chat-sender { text-align: left; }

  .chat-time {
    font-size: 10px;
    color: var(--text2);
    margin-top: 3px;
  }

  .chat-input-area {
    padding: 15px 20px;
    border-top: 1px solid var(--border);
    display: flex;
    gap: 10px;
    background: rgba(255,255,255,0.02);
