    font-family: 'Orbitron', monospace;
    font-size: 18px;
    font-weight: 900;
    width: 40px;
    text-align: center;
  }
  .lb-rank.r1 { color: var(--gold); text-shadow: 0 0 15px var(--gold); }
  .lb-rank.r2 { color: #c0c0c0; text-shadow: 0 0 10px #c0c0c0; }
  .lb-rank.r3 { color: #cd7f32; text-shadow: 0 0 10px #cd7f32; }
  .lb-avatar {
    width: 44px; height: 44px; border-radius: 50%;
