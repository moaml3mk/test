// ===== CHAT =====
let lastChatCount = 0;

function initChat() {
  renderChat();
  if (chatPollInterval) clearInterval(chatPollInterval);
  chatPollInterval = setInterval(renderChat, 2000);
  completeTask('t2_init');
}

function renderChat() {
  const msgs = getData('chat', []);
  const container = document.getElementById('chatMessages');
  if (!container) return;

  if (msgs.length === lastChatCount) return;
  lastChatCount = msgs.length;

  container.innerHTML = msgs.slice(-100).map(m => {
    const isOwn = m.user === currentUser.username;
    const isSystem = m.system;
    if (isSystem) {
      return `<div style="text-align:center;padding:8px;"><span style="background:rgba(0,212,255,0.1);border:1px solid rgba(0,212,255,0.2);border-radius:20px;padding:5px 15px;font-size:12px;color:var(--neon-blue);">${m.msg}</span></div>`;
    }
    return `
      <div class="chat-msg ${isOwn ? 'own' : ''}">
        <div class="chat-avatar">${m.user[0].toUpperCase()}</div>
        <div>
          <div class="chat-sender">${m.user}</div>
          <div class="chat-bubble">${escapeHTML(m.msg)}</div>
          <div class="chat-time">${m.time}</div>
        </div>
      </div>
    `;
  }).join('');

  container.scrollTop = container.scrollHeight;

  const users = getData('users', {});
  document.getElementById('chatOnlineCount').textContent = '👥 ' + Object.keys(users).length + ' مستخدم';
}

let userChatCount = 0;
function sendChat() {
  const input = document.getElementById('chatInput');
  const msg = input.value.trim();
  if (!msg) return;

  input.value = '';

  const chat = getData('chat', []);
  chat.push({ user: currentUser.username, msg, time: now() });
  if (chat.length > 500) chat.splice(0, chat.length - 500);
  setData('chat', chat);

  userChatCount++;
  if (userChatCount >= 5) { completeTask('t2'); userChatCount = 0; }

  renderChat();
}

