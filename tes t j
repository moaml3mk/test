        <td><div style="display:flex;gap:5px;align-items:center;">
          <input class="input-sm" type="number" id="sub_${u.username}" placeholder="100" min="1">
          <button class="btn-danger" onclick="adminEditPoints('${u.username}', 'sub')" style="font-size:11px;padding:5px 10px;">-</button>
        </div></td>
      </tr>
    `;
  }).join('') || '<tr><td colspan="7" style="text-align:center;color:var(--text2);padding:20px;">لا يوجد مستخدمون بعد</td></tr>';

  // Orders
  const adminOrders = document.getElementById('adminOrdersList');
  const allOrders = orders.slice().reverse();
  if (!allOrders.length) {
    adminOrders.innerHTML = '<div class="empty-state"><div class="icon">📭</div><p>لا يوجد طلبات</p></div>';
  } else {
    adminOrders.innerHTML = `<div style="display:flex;flex-direction:column;gap:10px;">` +
      allOrders.slice(0, 50).map((o, i) => `
        <div class="order-item" style="flex-wrap:wrap;gap:10px;">
          <div style="flex:1;min-width:200px;">
            <div style="font-weight:600;font-size:13px;">${o.service} <span style="color:var(--text2);font-size:11px;">(${o.user})</span></div>
            <div style="font-size:11px;color:var(--text2);word-break:break-all;">${o.link}</div>
            <div style="font-size:11px;color:var(--text2);">${o.createdAt} | الكمية: ${formatNum(o.qty || 1000)}</div>
          </div>
          <div style="display:flex;align-items:center;gap:8px;flex-wrap:wrap;">
            <span class="order-status status-${o.status}">${getStatusLabel(o.status)}</span>
            ${o.status === 'pending' ? `
              <button class="btn-success" onclick="adminChangeOrderStatus(${orders.indexOf(o)}, 'approved')" style="font-size:11px;">✅ موافقة</button>
              <button class="btn-primary" onclick="adminChangeOrderStatus(${orders.indexOf(o)}, 'completed')" style="font-size:11px;padding:6px 10px;background:linear-gradient(135deg,var(--neon-blue),var(--neon-green));">🎉 مكتمل</button>
              <button class="btn-danger" onclick="adminChangeOrderStatus(${orders.indexOf(o)}, 'rejected')" style="font-size:11px;">❌ رفض</button>
            ` : ''}
          </div>
        </div>
      `).join('') +
    `</div>`;
  }
}

function adminEditPoints(username, action) {
  const input = document.getElementById((action === 'add' ? 'add_' : 'sub_') + username);
  const amount = parseInt(input.value);
  if (!amount || amount < 1) { notify('⚠️ أدخل كمية صحيحة', 'error'); return; }

  const users = getData('users', {});
  if (!users[username]) { notify('❌ المستخدم غير موجود', 'error'); return; }

  if (action === 'add') {
    users[username].points = (users[username].points || 0) + amount;
    users[username].xp = (users[username].xp || 0) + Math.floor(amount * 0.5);
    notify('✅ تم إضافة ' + formatNum(amount) + ' نقطة لـ ' + username, 'success');
  } else {
    if ((users[username].points || 0) < amount) { notify('❌ النقاط غير كافية لدى المستخدم', 'error'); return; }
    users[username].points -= amount;
    notify('✅ تم خصم ' + formatNum(amount) + ' نقطة من ' + username, 'success');
  }

  setData('users', users);
  input.value = '';
  renderAdmin();
}

function adminChangeOrderStatus(index, status) {
  const orders = getData('orders', []);
  if (!orders[index]) return;
  orders[index].status = status;
  setData('orders', orders);

  if (status === 'completed') {
    const chat = getData('chat', []);
    chat.push({ user: 'AMOLI System', msg: `✅ تم إتمام طلب "${orders[index].service}" للمستخدم @${orders[index].user}`, time: now(), system: true });
    setData('chat', chat);
  }

  notify('✅ تم تغيير حالة الطلب إلى: ' + getStatusLabel(status), 'success');
  renderAdmin();
}

function adminBroadcast() {
  const msg = document.getElementById('broadcastMsg').value.trim();
  if (!msg) { notify('⚠️ اكتب رسالة أولاً', 'error'); return; }
  const chat = getData('chat', []);
  chat.push({ user: 'AMOLI System', msg: '📢 ' + msg, time: now(), system: true });
  setData('chat', chat);
  document.getElementById('broadcastMsg').value = '';
  notify('✅ تم إرسال الرسالة للجميع', 'success');
}

// ===== UI HELPERS =====
function notify(msg, type = 'info') {
  const el = document.getElementById('notification');
  el.textContent = msg;
  el.className = 'notif ' + type;
  el.style.display = 'block';
  clearTimeout(el._t);
  el._t = setTimeout(() => el.style.display = 'none', 3500);
}

function showErr(el, msg) {
  el.textContent = msg;
  el.style.display = 'block';
}

function formatNum(n) {
  return Number(n).toLocaleString('en-US');
}

function now() {
  return new Date().toLocaleTimeString('ar-SA', { hour: '2-digit', minute: '2-digit' });
}

function pad(n) {
  return String(n).padStart(2, '0');
}

function escapeHTML(str) {
  return str.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
}

// ===== PARTICLES =====
function createParticles() {
  const container = document.getElementById('particles');
  const colors = ['#00d4ff', '#ff0080', '#7928ca', '#00ff88', '#ff6600', '#ffd700'];
  for (let i = 0; i < 30; i++) {
    const p = document.createElement('div');
    p.className = 'particle';
    const color = colors[Math.floor(Math.random() * colors.length)];
    p.style.cssText = `
      background: ${color};
      box-shadow: 0 0 6px ${color};
      left: ${Math.random() * 100}vw;
      width: ${Math.random() * 3 + 1}px;
      height: ${Math.random() * 3 + 1}px;
      --drift: ${(Math.random() - 0.5) * 200}px;
      animation-duration: ${Math.random() * 15 + 10}s;
      animation-delay: ${Math.random() * 15}s;
    `;
    container.appendChild(p);
  }
}

createParticles();

// ===== KEYBOARD SHORTCUTS =====
document.addEventListener('keydown', e => {
  if (e.key === 'Escape') {
    document.getElementById('orderModal').classList.remove('active');
    document.getElementById('adminModal').classList.remove('active');
  }
});

// Close modal on overlay click
document.querySelectorAll('.modal-overlay').forEach(el => {
  el.addEventListener('click', e => { if (e.target === el) el.classList.remove('active'); });
});

// ===== INIT =====
navigate('landing');
</script>
