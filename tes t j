function changePassword() {
  if (isAdmin) { notify('⚠️ حساب الأدمن لا يمكن تغيير كلمة مروره هنا', 'error'); return; }
  const oldP = document.getElementById('oldPass').value;
  const newP = document.getElementById('newPass').value;

  if (!oldP || !newP) { notify('⚠️ أدخل كلمة المرور الحالية والجديدة', 'error'); return; }
  if (newP.length < 6) { notify('⚠️ كلمة المرور الجديدة يجب أن تكون 6 أحرف على الأقل', 'error'); return; }

  const users = getData('users', {});
  if (users[currentUser.username].password !== btoa(oldP)) {
    notify('❌ كلمة المرور الحالية غير صحيحة', 'error'); return;
  }

  users[currentUser.username].password = btoa(newP);
  setData('users', users);
  currentUser = users[currentUser.username];
  document.getElementById('oldPass').value = '';
  document.getElementById('newPass').value = '';
  notify('✅ تم تغيير كلمة المرور بنجاح', 'success');
  completeTask('t5');
}

