  .lb-tab.active { background: linear-gradient(135deg, var(--neon-blue), var(--neon-purple)); color: #fff; border-color: transparent; }

  /* ===== NOTIFICATIONS ===== */
  .notif-bell {
    position: relative;
    cursor: pointer;
    padding: 8px;
    border-radius: 10px;
    border: 1px solid var(--border);
    background: rgba(255,255,255,0.03);
    transition: all 0.3s;
    display: flex; align-items: center;
  }
  .notif-bell:hover { border-color: var(--neon-blue); box-shadow: 0 0 15px rgba(0,212,255,0.2); }
  .notif-dot {
    position: absolute; top: 4px; right: 4px;
    width: 8px; height: 8px; background: var(--neon-pink);
    border-radius: 50%; box-shadow: 0 0 8px var(--neon-pink);
    animation: pulse 2s infinite;
    display: none;
  }
  .notif-panel {
    position: fixed; top: 70px; left: 20px;
