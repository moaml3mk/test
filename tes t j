// ===== POINTS / XP =====
function addPoints(pts, xp, reason) {
  if (isAdmin) return;
  const users = getData('users', {});
  if (!users[currentUser.username]) return;
  users[currentUser.username].points = (users[currentUser.username].points || 0) + pts;
  users[currentUser.username].xp = (users[currentUser.username].xp || 0) + xp;
  setData('users', users);
  currentUser = users[currentUser.username];
  updateNavUser();
  if (reason) notify('💎 +' + pts + ' نقطة | ' + reason, 'success');
}

function deductPoints(pts) {
  if (isAdmin) return true;
  const users = getData('users', {});
  if (!users[currentUser.username]) return false;
  if (users[currentUser.username].points < pts) return false;
  users[currentUser.username].points -= pts;
  setData('users', users);
  currentUser = users[currentUser.username];
  updateNavUser();
  return true;
}

