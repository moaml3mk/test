function openOrderModal(serviceId) {
  selectedService = SERVICES.find(s => s.id === serviceId);
  if (!selectedService) return;
  document.getElementById('modalTitle').textContent = '⚡ ' + selectedService.name;
  document.getElementById('orderLink').value = '';
  document.getElementById('orderQty').value = '';
  document.getElementById('orderNotes').value = '';
  document.getElementById('orderCost').textContent = selectedService.cost;
  document.getElementById('orderModal').classList.add('active');

  document.getElementById('orderQty').oninput = function() {
    const qty = parseInt(this.value) || 0;
    const cost = Math.ceil((qty / 1000) * selectedService.cost) || selectedService.cost;
    document.getElementById('orderCost').textContent = formatNum(cost);
  };
}

function closeModal() {
  document.getElementById('orderModal').classList.remove('active');
}

function submitOrder() {
  if (!selectedService) return;
  const link = document.getElementById('orderLink').value.trim();
  const qty = parseInt(document.getElementById('orderQty').value) || 1000;
  const notes = document.getElementById('orderNotes').value.trim();

  if (!link) { notify('⚠️ أدخل رابط الحساب أو المنشور', 'error'); return; }

  const cost = Math.ceil((qty / 1000) * selectedService.cost) || selectedService.cost;

  if (!isAdmin && (currentUser.points || 0) < cost) {
    notify('❌ نقاطك غير كافية! اشحن من المتجر', 'error');
    closeModal();
    navigate('store');
    return;
  }

  if (!isAdmin) deductPoints(cost);

  const orders = getData('orders', []);
  orders.push({
    id: 'ORD' + Date.now(),
    user: currentUser.username,
    service: selectedService.name,
    platform: selectedService.platform,
    link, qty, notes, cost,
    status: 'pending',
    createdAt: new Date().toLocaleString('ar-SA')
  });
  setData('orders', orders);

  closeModal();
  notify('✅ تم إرسال طلبك بنجاح! سيتم مراجعته قريباً', 'success');
  navigate('orders');

  // Task completion
  completeTask('t6');
  completeTask('t3');
}

// ===== TASKS =====
function renderTasks() {
  const today = new Date().toDateString();
  const taskDates = getData('tasks_dates', {});
  const list = document.getElementById('tasksList');

  list.innerHTML = TASKS.map(t => {
    const key = (currentUser.username) + '_' + t.id;
    const done = taskDates[key] === today;
    return `
      <div class="task-item ${done ? 'done' : ''}" id="task-${t.id}">
        <div class="task-info">
          <div class="task-name">${t.name}</div>
          <div class="task-desc">${t.desc}</div>
        </div>
        <div style="display:flex;gap:10px;align-items:center;flex-wrap:wrap;">
          <div class="task-reward">+${t.points} 💎 | +${t.xp} XP</div>
          ${done
            ? '<span style="color:var(--neon-green);font-size:13px;">✅ مكتملة</span>'
            : `<button class="btn-success" onclick="completeTaskBtn('${t.id}')">إتمام</button>`}
        </div>
      </div>
    `;
  }).join('');
}

function completeTaskBtn(taskId) {
  const done = completeTask(taskId);
  if (done) renderTasks();
}

function completeTask(taskId) {
  if (isAdmin) return false;
  const today = new Date().toDateString();
  const taskDates = getData('tasks_dates', {});
  const key = currentUser.username + '_' + taskId;
  if (taskDates[key] === today) return false;

  const task = TASKS.find(t => t.id === taskId);
  if (!task) return false;

  taskDates[key] = today;
  setData('tasks_dates', taskDates);
  addPoints(task.points, task.xp, task.name);
  return true;
}

function startTaskTimer() {
  function updateTimer() {
    const now = new Date();
    const midnight = new Date(now);
    midnight.setHours(24, 0, 0, 0);
    const diff = midnight - now;
    const h = Math.floor(diff / 3600000);
    const m = Math.floor((diff % 3600000) / 60000);
    const s = Math.floor((diff % 60000) / 1000);
    const el = document.getElementById('taskTimer');
    if (el) el.textContent = `${pad(h)}:${pad(m)}:${pad(s)}`;
  }
  updateTimer();
  setInterval(updateTimer, 1000);
}

