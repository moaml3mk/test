// ===== LEVEL SYSTEM =====
function getLevel(xp) {
  const levels = [0, 500, 1200, 2500, 5000, 10000, 20000, 40000, 75000, 150000];
  let level = 1;
  for (let i = 0; i < levels.length; i++) {
    if (xp >= levels[i]) level = i + 1;
    else break;
  }
  return { level, current: levels[level - 1] || 0, next: levels[level] || levels[levels.length - 1] + 50000 };
}

function getLevelName(level) {
  const names = ['', 'Rookie', 'Bronze', 'Silver', 'Gold', 'Platinum', 'Diamond', 'Master', 'Legend', 'AMOLI King'];
  return names[level] || 'AMOLI King';
}

// ===== NAVIGATION =====
function navigate(page) {
  if (['home','services','tasks','store','orders','chat','profile','admin'].includes(page)) {
    if (!currentUser) { navigate('auth'); return; }
    if (page === 'admin' && !isAdmin) { navigate('home'); return; }
  }

  currentPage = page;
  document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
  const el = document.getElementById('page-' + page);
  if (el) el.classList.add('active');

  // Navbar
  const showNav = !['landing', 'auth'].includes(page);
  document.getElementById('navbar').style.display = showNav ? 'flex' : 'none';

  // Update active nav
  document.querySelectorAll('.nav-btn[data-page]').forEach(btn => {
    btn.classList.toggle('active', btn.dataset.page === page);
  });

  // Page-specific init
  if (page === 'home') renderDashboard();
  if (page === 'services') renderServices('all');
  if (page === 'tasks') renderTasks();
  if (page === 'store') renderStore();
  if (page === 'orders') renderOrders();
  if (page === 'chat') initChat();
  if (page === 'profile') renderProfile();
  if (page === 'admin') renderAdmin();
  if (page === 'tasks') startTaskTimer();
  if (page === 'store') updateStoreBalance();

  window.scrollTo(0, 0);
}

function showAuth(tab) {
  navigate('auth');
  switchTab(tab);
}

// ===== AUTH =====
function switchTab(tab) {
  document.getElementById('loginForm').style.display = tab === 'login' ? 'block' : 'none';
  document.getElementById('registerForm').style.display = tab === 'register' ? 'block' : 'none';
  document.getElementById('loginTab').classList.toggle('active', tab === 'login');
  document.getElementById('registerTab').classList.toggle('active', tab === 'register');
}

function register() {
  const username = document.getElementById('regUsername').value.trim();
  const email = document.getElementById('regEmail').value.trim();
  const pass = document.getElementById('regPassword').value;
  const confirm = document.getElementById('regConfirm').value;
  const errEl = document.getElementById('regError');
  const sucEl = document.getElementById('regSuccess');

  errEl.style.display = 'none';
  sucEl.style.display = 'none';

  if (!username || !email || !pass) { showErr(errEl, '⚠️ يرجى ملء جميع الحقول'); return; }
  if (username.length < 3) { showErr(errEl, '⚠️ اسم المستخدم يجب أن يكون 3 أحرف على الأقل'); return; }
  if (pass.length < 6) { showErr(errEl, '⚠️ كلمة المرور يجب أن تكون 6 أحرف على الأقل'); return; }
  if (pass !== confirm) { showErr(errEl, '⚠️ كلمتا المرور غير متطابقتين'); return; }

  const users = getData('users', {});
  if (users[username]) { showErr(errEl, '⚠️ اسم المستخدم مأخوذ، اختر اسماً آخر'); return; }

  users[username] = {
    username, email,
    password: btoa(pass),
    points: 200,
    xp: 100,
    joinDate: new Date().toLocaleDateString('ar-SA'),
    createdAt: Date.now()
  };
  setData('users', users);

  // Welcome chat message
  const chat = getData('chat', []);
  chat.push({ user: 'AMOLI System', msg: `🎉 مرحباً بـ ${username} في منصة AMOLI!`, time: now(), system: true });
  setData('chat', chat);

  sucEl.textContent = '✅ تم إنشاء حسابك! يمكنك تسجيل الدخول الآن';
  sucEl.style.display = 'block';
  setTimeout(() => switchTab('login'), 1500);
}

function login() {
  const username = document.getElementById('loginUsername').value.trim();
  const pass = document.getElementById('loginPassword').value;
  const errEl = document.getElementById('loginError');

  errEl.style.display = 'none';

  if (!username || !pass) { showErr(errEl, '⚠️ أدخل اسم المستخدم وكلمة المرور'); return; }

  const users = getData('users', {});
  const user = users[username];

  if (!user || user.password !== btoa(pass)) {
    showErr(errEl, '❌ اسم المستخدم أو كلمة المرور غير صحيح');
    return;
  }

  currentUser = user;
  isAdmin = false;
  afterLogin();
}

