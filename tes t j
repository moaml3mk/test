  .notif-item.unread { background: rgba(0,212,255,0.03); border-right: 3px solid var(--neon-blue); }
  .notif-item-title { font-size: 13px; font-weight: 600; margin-bottom: 3px; }
  .notif-item-time { font-size: 11px; color: var(--text2); }

  /* ===== SPIN
  .input-group select {
    width: 100%;
    padding: 14px 20px;
    background: rgba(0,212,255,0.05);
