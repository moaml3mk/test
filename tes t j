    border-radius: 50px;
    color: #fff;
    font-family: 'Cairo', sans-serif;
    font-size: 16px;
    font-weight: 700;
    cursor: pointer;
    transition: all 0.3s;
    box-shadow: 0 0 30px rgba(0,212,255,0.3);
  }

  .hero-btn-primary:hover {
    transform: translateY(-3px);
    box-shadow: 0 10px 50px rgba(0,212,255,0.5);
  }

  .hero-btn-outline {
    padding: 16px 40px;
    background: transparent;
    border: 1px solid var(--border);
    border-radius: 50px;
    color: var(--text);
    font-family: 'Cairo', sans-serif;
    font-size: 16px;
    cursor: pointer;
    transition: all 0.3s;
  }

  .hero-btn-outline:hover {
    border-color: var(--neon-pink);
    color: var(--neon-pink);
    box-shadow: 0 0 25px rgba(255,0,128,0.2);
  }

  .features-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 15px;
    margin-top: 40px;
  }

  .feature-card {
    background: rgba(255,255,255,0.02);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 20px;
    text-align: center;
    transition: all 0.3s;
  }

  .feature-card:hover {
    border-color: var(--neon-blue);
    box-shadow: 0 0 20px rgba(0,212,255,0.1);
    transform: translateY(-3px);
  }

  .feature-card .icon { font-size: 28px; margin-bottom: 10px; }
  .feature-card h4 { font-size: 14px; font-weight: 600; margin-bottom: 5px; }
  .feature-card p { font-size: 12px; color: var(--text2); }

  /* ===== LEADERBOARD ===== */
  .lb-item {
    display: flex;
    align-items: center;
    gap: 15px;
    padding: 14px 20px;
    background: rgba(255,255,255,0.02);
    border: 1px solid var(--border);
    border-radius: 12px;
    transition: all 0.3s;
    margin-bottom: 10px;
  }
  .lb-item:hover { transform: translateX(-5px); border-color: rgba(0,212,255,0.4); }
